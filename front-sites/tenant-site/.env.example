# API base URL (without tenant). The app will prefix the tenant subdomain at runtime.
# Example: https://api.onlineschoolmultitenant.com/api
#          → for tenant "foo" (foo.onlineschoolmultitenant.com) becomes https://foo.api.onlineschoolmultitenant.com/api
VITE_API_BASE_URL=https://api.onlineschoolmultitenant.com/api

# App name (optional)
VITE_APP_NAME=EduCore

# Dev only: when running on plain localhost, set a tenant to use for API base URL.
# Example: VITE_TENANT_ID=foo → API base becomes http://foo.localhost:8000/api if VITE_API_BASE_URL is http://localhost:8000/api
# VITE_TENANT_ID=foo
